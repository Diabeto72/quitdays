<?xml version="1.0" encoding="utf-8"?>
<!-- Glowing streak ring: cyan→purple gradient circle with neon border -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="oval">
            <gradient
                android:type="linear"
                android:angle="135"
                android:startColor="@color/streak_start"
                android:endColor="@color/streak_end" />
            <stroke
                android:width="2dp"
                android:color="@color/primary" />
        </shape>
    </item>
</layer-list>
